# Copy to .env and fill in. For local dev, also add .env.local (see .env.local.example).

NODE_ENV=development
PORT=5001

JWT_SECRET=use-a-long-random-string-in-real-deploys
JWT_EXPIRE=7d

FRONTEND_URL=http://localhost:3000

UPLOAD_PATH=../uploads
MAX_FILE_SIZE=104857600
MAX_ARTIFACT_SIZE=104857600
MAX_GALLERY_SIZE=209715200

# Optional: JSON data directory (default: <repo>/data). Relative paths are from repo root.
# DATA_DIR=data

EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
ADMIN_EMAIL=
